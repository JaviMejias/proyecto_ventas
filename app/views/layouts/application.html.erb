<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Proyecto Ventas" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-controller="flash <%= controller_name.underscore.dasherize %> modal"
        data-success="<%= j flash[:notice] %>"
        data-error="<%= j flash[:alert] %>"
        class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 min-h-screen font-['Outfit'] transition-colors duration-300"
  >
    <% if user_signed_in? %>
      <%= render 'shared/navigation' %>
    <% end %>
    <% if devise_controller? %>
      <%= yield %>
    <% else %>
      <main class="container mx-auto px-4 sm:px-6 lg:px-8 mt-6 mb-12">
        <div class="w-full p-4 sm:p-8 bg-white dark:bg-slate-800 rounded-3xl shadow-xl border border-slate-100 dark:border-slate-700/50 transition-colors duration-300"> 
          <%= yield %>
        </div>
      </main>
    <% end %>
  </body>
</html>